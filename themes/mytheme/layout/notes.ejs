<section class="main-section">   
  <!-- ============================
       在线笔记系统模块
       功能：
         - 列出已有文章
         - 新建文章
         - 编辑文章（标题、分类、标签、内容）
         - 实时 Markdown 预览
         - 保存到 GitHub 仓库，触发 Vercel 自动部署
  ============================ -->
  <h1 style="text-align:center;">📒 在线笔记系统</h1>

  <div style="max-width:1000px; margin:20px auto;">
    <!-- 新建文章按钮 -->
    <button id="newNoteBtn" style="padding:10px 15px; background:#0078d7; color:#fff; border:none; border-radius:5px; cursor:pointer;">📝 新建文章</button>

    <!-- 文章列表容器 -->
    <div id="noteList" style="margin-top:20px;"></div>
  </div>

  <script>
  const owner = "Sun1105";              // 替换成你的 GitHub 用户名
  const repo = "hexo-source";           // 替换成你的仓库名
  const postsDir = "source/_posts";     // Hexo 文章目录
  const isLocal = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';

  const noteListDiv = document.getElementById('noteList');

  // ========================
  // 1️⃣ 列出文章列表
  // ========================
  async function loadNotes() {
    noteListDiv.innerHTML = "加载中...";
    try {
      const fetchUrl = isLocal 
        ? `/api/list-posts?path=${encodeURIComponent(postsDir)}`
        : `https://api.github.com/repos/${owner}/${repo}/contents/${postsDir}`;
        
      const res = await fetch(fetchUrl);
      const data = await res.json();
      if(res.ok){
        noteListDiv.innerHTML = "";
        data.forEach(file => {
        if(file.name.endsWith(".md")){
          const div = document.createElement('div');
          div.className = "note-item";

          // 左侧：图标 + 文件名
          const left = document.createElement('div');
          left.style.display = "flex";
          left.style.alignItems = "center";

          const icon = document.createElement('span');
          icon.className = "note-icon";
          icon.textContent = "📄";

          const title = document.createElement('span');
          title.className = "note-title";
          title.textContent = file.name;

          left.appendChild(icon);
          left.appendChild(title);

          // 右侧：附加信息（比如更新时间）
          const meta = document.createElement('span');
          meta.className = "note-meta";
          meta.textContent = (file.size / 1024).toFixed(1) + " KB";

          div.appendChild(left);
          div.appendChild(meta);

          // 使用全局 openEditor 函数
          div.addEventListener('click', () => {
             if (window.openEditor) {
                window.openEditor(file);
             } else {
                alert('Editor component not loaded.');
             }
          });
          noteListDiv.appendChild(div);
        }
        });
      } else {
        noteListDiv.innerHTML = "❌ 获取文章列表失败：" + JSON.stringify(data);
      }
    } catch(err){
      noteListDiv.innerHTML = "❌ 网络错误：" + err.message;
    }
  }

  // ========================
  // 2️⃣ 新建文章
  // ========================
  document.getElementById('newNoteBtn').addEventListener('click', () => {
      if (window.openEditor) {
          window.openEditor(null);
      } else {
          alert('Editor component not loaded.');
      }
  });

  // ========================
  // 3️⃣ 初始化加载文章列表
  // ========================
  loadNotes();
  // 暴露 loadNotes 给全局，以便保存后刷新
  window.loadNotes = loadNotes;
  </script>
  <style>
    /* 文件列表整体容器 */
    #noteList {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    /* 单个文章项 */
    .note-item {
      padding: 12px 16px;
      border: 1px solid #e0e0e0;
      border-radius: 6px;
      background: #fafafa;
      transition: all 0.2s ease;
      font-family: "Segoe UI", sans-serif;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    /* 鼠标悬停效果 */
    .note-item:hover {
      background: #f0f8ff;
      border-color: #0078d7;
      transform: translateY(-2px);
      cursor: pointer;
    }

    /* 文件名 */
    .note-title {
      font-weight: 600;
      color: #333;
    }

    /* 文件图标 */
    .note-icon {
      margin-right: 8px;
      color: #0078d7;
    }

    /* 时间戳或附加信息 */
    .note-meta {
      font-size: 12px;
      color: #666;
    }
  </style>
</section>
