<section class="main-section">   
  <!-- ============================
       新建笔记模块（分类下拉 + 标签自动提示）
       功能：
         - 选择已有分类
         - 输入标签（逗号分隔）
         - 输入标题、正文
         - 提交表单到 Vercel API
  ============================ -->

  <h1 style="text-align:center;">📝 新建笔记</h1>

  <form id="newNoteForm">
    <!-- 标题输入 -->
    <label for="title">标题：</label>
    <input type="text" id="title" name="title" required>

    <!-- 分类下拉选择 -->
    <label for="category">分类：</label>
    <select id="category" name="category" required>
      <option value="">请选择分类</option>
      <% if (site.categories && site.categories.length) { %>
        <% site.categories.sort('name').forEach(function(cat){ %>
          <option value="<%= cat.name %>"><%= cat.name %></option>
        <% }); %>
      <% } %>
    </select>

    <!-- 标签输入 -->
    <label for="tags">标签（用逗号分隔）：</label>
    <input type="text" id="tags" name="tags" placeholder="例如 Java, Stream">

    <!-- 内容输入 -->
    <label for="content">内容：</label>
    <textarea id="content" name="content" rows="10" required></textarea>

    <!-- 提交按钮 -->
    <button type="submit">提交</button>
  </form>

  <style>
    /* 表单整体样式 */
    #newNoteForm { 
      max-width: 1200px; 
      margin: 40px auto; 
      padding:25px; 
      border:1px solid #ddd; 
      border-radius:8px; 
      background:#fafafa; 
      font-family:"Segoe UI",sans-serif; 
    }
    #newNoteForm label { display:block; margin:15px 0 5px; font-weight:bold; }
    #newNoteForm input, #newNoteForm textarea, #newNoteForm select { 
      width:100%; padding:10px; border:1px solid #ccc; border-radius:6px; margin-bottom:10px; font-size:14px; 
    }
    #newNoteForm button { width:100%; padding:12px; background:#0078d7; color:#fff; border:none; border-radius:6px; cursor:pointer; font-weight:bold; }
    #newNoteForm button:hover { background:#005a9e; }
  </style>

  <script>
    document.getElementById('newNoteForm').addEventListener('submit', async function(e){
      e.preventDefault();

      const form = e.target;
      const title = form.title.value;
      const category = form.category.value;
      const tags = form.tags.value.split(',').map(t => t.trim()).filter(Boolean);
      const content = form.content.value;
      const isLocal = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';

      // 构造符合 Hexo 标准的 Markdown 内容
      let fullContent = "---\n";
      fullContent += `title: ${title}\n`;
      fullContent += `date: ${new Date().toISOString()}\n`;
      if (category) fullContent += `categories: [${category}]\n`;
      if (tags.length) fullContent += `tags: [${tags.join(', ')}]\n`;
      fullContent += "---\n\n";
      fullContent += content;

      // 生成文件名
      const filename = `source/_posts/${Date.now()}.md`;

      const payload = {
        path: filename,
        title: title, // 保持对旧接口的兼容
        content: fullContent,
        message: `Create note: ${title}`
      };

      try {
        const res = await fetch('/api/new-note', {
          method: 'POST',
          headers: {'Content-Type':'application/json'},
          body: JSON.stringify(payload)
        });

        const data = await res.json();

        if(res.ok){
          alert('✅ 笔记创建成功！');
          window.location.href = '/'; 
        } else {
          // 如果远程服务器报错，提供更详细的提示
          let errMsg = data.error || JSON.stringify(data);
          if (!isLocal && errMsg.includes("GITHUB_TOKEN")) {
             errMsg = "远程服务器未配置 GITHUB_TOKEN，请检查 Vercel 环境变量设置。";
          }
          alert('❌ 创建失败：' + errMsg);
        }
      } catch(err){
        alert('❌ 网络或服务器错误：' + err.message);
      }
    });
  </script>
</section>
