{
  "version": "0.2.0",
  "configurations": [
  
    {
      "name": "🔹 调试 Hexo 本地服务器",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/hexo/bin/hexo",
      "args": ["server"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "🔹 调试 API（Serverless Function）",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/api/new-note.js",
      "console": "integratedTerminal"
    }
  ]
}
